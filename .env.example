# OpenRouter — single key for all LLM calls across agents
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model for data agents (Equifax, Employment, Intl)
OPENROUTER_AGENT_MODEL=google/gemini-3-flash

# Model for Risk Synthesis Agent
OPENROUTER_SYNTHESIS_MODEL=openai/gpt-5.4-mini

# Agent Registry URL
# - Docker Compose: http://registry:8099 (uses Docker service name)
# - Local dev: http://localhost:8099
AGENT_REGISTRY_URL=http://registry:8099

# Global A2A task timeout in seconds
AGENT_TIMEOUT_SECONDS=30
